[
  {
    "hash": "sha256:c80b14535c48aeefe9108afe15bfe3fcad58ef1470910fc62ad506e1b3a60a75",
    "text": "오늘 여기까지 온 것만으로도 충분해."
  },
  {
    "hash": "sha256:e1e2b0d9b2839f34e0378a52914e96b960bd61be2e58411db0950408d81dd80c",
    "text": "속도가 느려도 앞으로 가고 있어."
  },
  {
    "hash": "sha256:a99de9eb6ebcd5884dedf4afceedf3801fa58f9c39813e13340b89c5038881ba",
    "text": "잘 안 풀리는 순간도 과정의 일부야."
  },
  {
    "hash": "sha256:8f634badb737b5849758d9cd0dce50601887fda27b3d6acaca3cf707fbbb6875",
    "text": "잠깐 쉬어도 네가 해낸 건 사라지지 않아."
  },
  {
    "hash": "sha256:c6ee640744ad8599848bcd1a4d027f67981c80d1e80b97d46ef5c23f9391d566",
    "text": "완벽하지 않아도 괜찮아. 계속하고 있잖아."
  },
  {
    "hash": "sha256:490b911db7d75ec43a6addc4d1cd9b79a454fba635b585175349c40602d2dd24",
    "text": "작은 진전도 분명한 진전이야."
  },
  {
    "hash": "sha256:18a87bd66d8bdacb002c934ea8286033b2db46aa20f7f24e0c3ea8a91d04e32e",
    "text": "지금 버티고 있는 너도 꽤 대단해."
  },
  {
    "hash": "sha256:391e7610fcf2440a34b9caa858ac5db781ca8748e9e3f1b908ebf4fd11c6d1b5",
    "text": "한 번에 다 해내지 않아도 돼."
  },
  {
    "hash": "sha256:26bb7a94e441a1ba50276c54fc7dcfda968f674f48ceca00a9f20a58c214cf3a",
    "text": "오늘의 너에게 너무 엄격하지 않았으면 해."
  },
  {
    "hash": "sha256:103fe1bc536c6137507dec6d9d14444c2f30bc9fdacd234afbd2e2a5edbb6a43",
    "text": "조용히 곁에 있을게. 천천히 해."
  },
  {
    "hash": "sha256:5dc88c2b218d3692cfcb21e731782f2a9c46c5a852e68554376eebbfbe2c3a53",
    "text": "숨 한번 고르고 다시 시작해도 괜찮아."
  },
  {
    "hash": "sha256:702c6d88ee09b5c53e68f0d29931778119515485cd773f2b2949e3751ed1faf2",
    "text": "남들과 다른 속도여도 네 길은 틀리지 않아."
  },
  {
    "hash": "sha256:2069ec81dfb5a7225b35495119627d9f30f634f640dc2af64769cce5ef725ad9",
    "text": "실수는 네가 부족하다는 증거가 아니야."
  },
  {
    "hash": "sha256:7a74b93481c385f7235ed325b6732f371bb27392945eb71abbeabb009dcafb6d",
    "text": "어려운 걸 하고 있으니 어려운 게 당연해."
  },
  {
    "hash": "sha256:bdafc3e5804a948095b0a3c032634f094dfcc502e04e9150105352c58320ec4e",
    "text": "시작한 것만으로도 이미 한 걸음 나아갔어."
  },
  {
    "hash": "sha256:d85ea90308bfa38df95e9b7e30aee681978b6a1829d23d3ed297901823310c67",
    "text": "마음이 무거운 날엔 가볍게 해도 괜찮아."
  },
  {
    "hash": "sha256:e401c1d56926616d05174391d0b88ebddd1b61d8c917a7379e2cd45bc441eeea",
    "text": "네가 들인 노력은 생각보다 오래 남아."
  },
  {
    "hash": "sha256:160315e13e9011eed972b658e623cb674be3a5f8b7e3c7aa3524b94d12aaa159",
    "text": "지금 당장 답을 찾지 못해도 괜찮아."
  },
  {
    "hash": "sha256:1575f6eccd40f2a351ed9f2584c009371d96b83c68143118f2c1e2319a3e5e2e",
    "text": "천천히 해도 돼. 나는 여기 있을게."
  },
  {
    "hash": "sha256:ec5a69ec3969e8f480df45960706de1c895f9d6c62c57dac57302922b1ff9902",
    "text": "오늘 못한 일보다 해낸 일을 먼저 봐줘."
  }
]
