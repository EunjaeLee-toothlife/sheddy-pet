[
  {
    "hash": "sha256:dbc249d2334ec9d1a85e4a242ef8e0cb31fa6314a0fc938a56bb9b0594f9e522",
    "text": "오늘의 특별 공연이야."
  },
  {
    "hash": "sha256:50b09712e6a2f1daab13c2017bc2b5b2b4053f0fa1ad335a9c41c54e45ae9dee",
    "text": "잠깐, 이건 꼭 봐줘."
  },
  {
    "hash": "sha256:b5d14745c72981b16a3e1cb68d0e8c6c6e6beaa681bbf943de8b83050b93ae4a",
    "text": "이 정도는 해야 특별하지."
  },
  {
    "hash": "sha256:70917e311ab253d01f22b649b50a555feb6aed57da91c9996df864e4d6d934e9",
    "text": "분위기 전환이 필요해 보여서."
  },
  {
    "hash": "sha256:8f5ab98c89b207bf3ad870c0df988207c5e14aee719f0f1cc57c27717177c8ac",
    "text": "짜잔, 이런 건 어때?"
  }
]
